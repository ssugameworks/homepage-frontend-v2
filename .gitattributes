# 모든 텍스트 파일은 LF로 통일
* text=auto eol=lf

# 명시적으로 텍스트 처리할 파일들
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.sh   text eol=lf

# 바이너리 파일은 변환 안 함
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary
*.woff binary
*.woff2 binary
